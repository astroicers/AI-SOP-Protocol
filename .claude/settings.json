{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.asp/hooks/clean-allow-list.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.asp/hooks/session-audit.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "ask": [
      "Bash(docker deploy *)",
      "Bash(docker push *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git rebase *)",
      "Bash(git rebase)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)"
    ]
  }
}
