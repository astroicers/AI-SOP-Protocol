{
  "version": 1,
  "confidence_threshold": 0.8,
  "fallback": { "type": "GENERAL", "confidence": 0.3, "reason": "複合需求，需進一步分解" },
  "types": [
    { "type": "REMOVAL", "priority": 1, "reason": "包含移除/刪除意圖",
      "keywords": ["remove", "delete", "deprecate", "drop", "cleanup", "移除", "刪除", "廢棄", "拿掉", "砍掉"] },
    { "type": "BUGFIX", "priority": 2, "reason": "包含修復/錯誤意圖",
      "keywords": ["bug", "fix", "broken", "error", "crash", "regression", "修復", "修 bug", "錯誤", "壞了", "不正常", "hotfix"] },
    { "type": "MODIFICATION", "priority": 3, "reason": "修改既有功能",
      "keywords": ["modify", "change", "update", "refactor", "adjust", "optimize", "修改", "調整", "重構", "優化", "改善"],
      "post_checks": ["target_exists_in_codebase"] },
    { "type": "NEW_FEATURE", "priority": 4, "reason": "包含新增/建立意圖",
      "keywords": ["add", "create", "implement", "build", "新增", "建立", "實作", "開發"] }
  ],
  "bug_domains": [
    { "domain": "auth",
      "keywords": ["login", "token", "JWT", "permission", "RBAC", "session", "認證", "授權", "登入", "權限", "未授權"],
      "add_agents": ["sec"],
      "grep_hint": "擴大掃描到所有 auth 相關模組（auth/, permission/, rbac/, session/, middleware/auth）",
      "force_full_test": false, "force_state_scan": false },
    { "domain": "concurrency",
      "keywords": ["race", "concurrent", "deadlock", "mutex", "lock", "atomic", "channel", "goroutine", "競爭", "死鎖", "並發"],
      "add_agents": ["dep-analyst"],
      "grep_hint": "搜尋所有共享狀態存取點（*cache*|*queue*|*worker*|*pool*）",
      "force_full_test": false, "force_state_scan": false },
    { "domain": "data_integrity",
      "keywords": ["schema", "migration", "constraint", "FK", "unique", "duplicate", "資料遺失", "遷移", "外鍵"],
      "add_agents": [],
      "grep_hint": "掃描同 schema 的所有 CRUD 操作（model/, migration/, db/, store/, repository/）",
      "force_full_test": true, "force_state_scan": false },
    { "domain": "api_contract",
      "keywords": ["API", "response", "status code", "breaking", "contract", "endpoint", "schema mismatch"],
      "add_agents": ["sec", "dep-analyst"],
      "grep_hint": "掃描所有消費該 API 的 client 端（api/, handler/, routes/, controller/）",
      "force_full_test": false, "force_state_scan": false },
    { "domain": "state_machine",
      "keywords": ["state", "transition", "status", "workflow", "FSM", "狀態", "流程", "invalid state", "illegal transition"],
      "add_agents": [],
      "grep_hint": "掃描所有狀態轉換點與依賴該狀態的消費者",
      "force_full_test": false, "force_state_scan": true },
    { "domain": "boundary",
      "keywords": ["edge case", "boundary", "overflow", "off-by-one", "empty", "max", "min", "zero", "邊界", "溢位"],
      "add_agents": [],
      "grep_hint": "掃描同模組所有比較運算和邊界檢查",
      "force_full_test": false, "force_state_scan": false },
    { "domain": "null_safety",
      "keywords": ["null", "nil", "undefined", "NullPointer", "Cannot read", "空指標", "nil pointer", "null reference"],
      "add_agents": [],
      "grep_hint": "掃描同模組所有未檢查的 nullable 存取",
      "force_full_test": false, "force_state_scan": false }
  ]
}
